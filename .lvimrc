"Automatically detect nearest Makefile and set ALE root accordingly -> From awful ChatGPT
set mouse=a
set clipboard=unnamedplus
let g:ale_linters = { 'cpp' : ['cc']  }
let g:ale_cpp_cc_options = '-I include/ -Wall -Wextra -Werror -std=c++98'

function! s:DetectMakefileRoot() abort
	  " Start from the directory of the current file
	let l:dir = expand('%:p:h')     
	  " Walk upward until we find a Makefile or reach the filesystem root
	while l:dir !=# '/' && !filereadable(l:dir . '/Makefile')
		let l:parent = fnamemodify(l:dir, ':h')
		if l:parent ==# l:dir
			break
		endif
		let l:dir = l:parent
	endwhile
	" If we found a Makefile, set buffer-local ALE options
	if filereadable(l:dir . '/Makefile')
  		let b:ale_root = l:dir
  	endif
endfunction

"" Automatically run the function when opening C files
augroup ALEMakefileDetection
	autocmd!
	autocmd BufRead,BufNewFile *.c,*.h,*.cpp,*.hpp call s:DetectMakefileRoot()
augroup END
